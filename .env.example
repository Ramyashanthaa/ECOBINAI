# ── Gemma 4 Model Backend ─────────────────────────────────────────────────────
# Choose one: "google_ai_studio" | "ollama" | "huggingface"
GEMMA_BACKEND=google_ai_studio

# Google AI Studio (free tier: 1,500 req/day)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=AIzaSyAGgaxRe_Ua-gVrrFUVuEsh0Nw1bdDBkik

# Model size: gemma-4-e2b-it | gemma-4-e4b-it | gemma-4-27b-it
GEMMA_MODEL=gemma-4-31b-it

# ── Ollama (local / edge / offline) ───────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4

# ── Hardware Mode ─────────────────────────────────────────────────────────────
# Set to "true" only when running on Raspberry Pi with servos wired up
HARDWARE_MODE=false

# Servo driver — "gpio" (direct PWM on GPIO pins) or "pca9685" (I2C 16-channel)
HARDWARE_DRIVER=pca9685

# GPIO BCM pins (used only when HARDWARE_DRIVER=gpio)
SERVO_PIN_RECYCLABLE=17
SERVO_PIN_COMPOST=27
SERVO_PIN_TRASH=22
SERVO_PIN_HAZARDOUS=10

# PCA9685 I2C servo driver (used when HARDWARE_DRIVER=pca9685)
PCA9685_ADDRESS=0x40
PCA9685_FREQ_HZ=50
PCA9685_CHANNEL_RECYCLABLE=0
PCA9685_CHANNEL_COMPOST=4
PCA9685_CHANNEL_TRASH=8
PCA9685_CHANNEL_HAZARDOUS=12

# SG90 calibration (microseconds at closed/open angles)
SERVO_CLOSED_US=600
SERVO_OPEN_US=2400

# ── Camera ────────────────────────────────────────────────────────────────────
# Camera index (0 = built-in/first USB), or full path for Pi camera
CAMERA_INDEX=0
CAMERA_RESOLUTION_W=640
CAMERA_RESOLUTION_H=480

# Headless USB-camera capture loop — true for standalone Pi mode (no browser).
# Leave false for cloud/dev deployments where the browser sends frames.
USB_CAMERA_ENABLED=false
USB_CAMERA_INTERVAL_S=1.5
USB_CAMERA_SCENE_DIFF_THRESHOLD=12

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite:///./ecobin.db

# Lid open duration in seconds
LID_OPEN_DURATION=5
